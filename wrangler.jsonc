{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "omegasqua",
  "main": "_worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ALLOWED_ORIGINS": "https://omegasqua.my.id,https://www.omegasqua.my.id",
    "APP_GAS_URL": "https://script.google.com/macros/s/AKfycby177xpnmdGhd6PoWzUujqk19G2FN2g04yKwXzNSXF9pg1iNLus6ZswEEJ0sAm0TbG4zQ/exec",
    "MOOTA_GAS_URL": "https://script.google.com/macros/s/AKfycby177xpnmdGhd6PoWzUujqk19G2FN2g04yKwXzNSXF9pg1iNLus6ZswEEJ0sAm0TbG4zQ/exec"
  },
  "env": {
    "staging": {
      "name": "omegasqua-web-staging",
      "vars": {
        "ALLOWED_ORIGINS": "https://staging.omegasqua.my.id",
        "APP_GAS_URL": "https://script.google.com/macros/s/AKfycby177xpnmdGhd6PoWzUujqk19G2FN2g04yKwXzNSXF9pg1iNLus6ZswEEJ0sAm0TbG4zQ/exec",
        "MOOTA_GAS_URL": "https://script.google.com/macros/s/AKfycby177xpnmdGhd6PoWzUujqk19G2FN2g04yKwXzNSXF9pg1iNLus6ZswEEJ0sAm0TbG4zQ/exec"
      }
    }
  }
}
